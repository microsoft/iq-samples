# =============================================================================
# Azure AI Foundry project
# =============================================================================
# Your Foundry project endpoint (Foundry portal → project → Overview)
FOUNDRY_PROJECT_ENDPOINT=https://<your-account>.services.ai.azure.com/api/projects/<your-project-name>

# Model deployment name — must match a model deployed in your Foundry project
FOUNDRY_MODEL=gpt-4.1

# =============================================================================
# Foundry IQ knowledge base (only needed when CREATING the knowledge base —
# the hosted agent injects the KB automatically at runtime via the manifest)
# =============================================================================
# Azure AI Search service backing the Foundry IQ knowledge base
AZURE_AI_SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net

# Optional: API key for local knowledge-base setup. Prefer `az login` / RBAC
# (DefaultAzureCredential) over keys. NEVER commit a real key.
# AZURE_AI_SEARCH_API_KEY=<your-search-api-key>
